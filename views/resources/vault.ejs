<%- include('../partials/header', { user: user }) %>

<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h4 class="mb-1">Resource Vault</h4>
      <p class="text-muted small mb-0">
        Project: <strong><%= opportunity.title %></strong>
      </p>
    </div>
    <a href="/milestones/<%= opportunity._id %>" class="btn btn-outline-dark btn-sm">
      📊 Progress Dashboard
    </a>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h6 class="mb-3">Upload File</h6>
      <form action="/resources/<%= opportunity._id %>/upload"
            method="POST" enctype="multipart/form-data">
        <div class="row g-2">
          <div class="col-md-4">
            <input type="file" name="file" class="form-control" required>
          </div>
          <div class="col-md-4">
            <input type="text" name="description" class="form-control"
                   placeholder="Short description (optional)">
          </div>
          <div class="col-md-2">
            <select name="fileType" class="form-select">
              <option value="resource">Resource</option>
              <option value="report">Progress Report</option>
            </select>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-dark w-100">Upload</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6 mb-4">
      <h6 class="mb-3">📚 Resources
        <span class="badge bg-secondary"><%= resources.length %></span>
      </h6>

      <% if (resources.length === 0) { %>
        <p class="text-muted small">No resources uploaded yet.</p>
      <% } else { %>
        <% resources.forEach(function(file) { %>
          <div class="card mb-2 shadow-sm">
            <div class="card-body py-2 px-3">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="mb-0 small fw-bold">📄 <%= file.originalName %></p>
                  <small class="text-muted">
                    By <%= file.uploadedBy.name %> &middot;
                    <%= new Date(file.createdAt).toLocaleDateString() %>
                  </small>
                  <% if (file.description) { %>
                    <br><small class="text-muted"><%= file.description %></small>
                  <% } %>
                </div>
                <div class="d-flex gap-2">
                  <a href="<%= file.fileUrl %>" target="_blank"
                     class="btn btn-outline-dark btn-sm">Download</a>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>

    <div class="col-md-6 mb-4">
      <h6 class="mb-3">📝 Progress Reports
        <span class="badge bg-secondary"><%= reports.length %></span>
      </h6>

      <% if (reports.length === 0) { %>
        <p class="text-muted small">No reports uploaded yet.</p>
      <% } else { %>
        <% reports.forEach(function(file) { %>
          <div class="card mb-2 shadow-sm">
            <div class="card-body py-2 px-3">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <p class="mb-0 small fw-bold">📄 <%= file.originalName %></p>
                  <small class="text-muted">
                    By <%= file.uploadedBy.name %> &middot;
                    <%= new Date(file.createdAt).toLocaleDateString() %>
                  </small>
                  <% if (file.description) { %>
                    <br><small class="text-muted"><%= file.description %></small>
                  <% } %>
                </div>
                <div class="d-flex gap-2">
                  <a href="<%= file.fileUrl %>" target="_blank"
                     class="btn btn-outline-dark btn-sm">Download</a>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

</div>

<%- include('../partials/footer') %>