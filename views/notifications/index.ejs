<%- include('../partials/header', { user }) %>

<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4>Notifications</h4>
    <button onclick="markAllRead()" class="btn btn-sm btn-outline-secondary">
      Mark all as read
    </button>
  </div>

  <div id="notificationList">
    <% if (notifications.length === 0) { %>
      <div class="text-center text-muted mt-5">
        <h5>No notifications yet</h5>
      </div>
    <% } %>

    <% notifications.forEach(n => { %>
      <div class="card mb-2 notification-card <%= n.isRead ? '' : 'unread' %>" 
           data-id="<%= n._id %>">
        <div class="card-body py-3">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <% if (!n.isRead) { %>
                <span class="unread-dot"></span>
              <% } %>
              <span class="<%= n.isRead ? 'text-muted' : '' %>">
                <%= n.message %>
              </span>
              <br>
              <small class="text-muted">
                <%= new Date(n.createdAt).toLocaleString() %>
              </small>
            </div>
            <% if (!n.isRead) { %>
              <button onclick="markRead('<%= n._id %>')" 
                class="btn btn-sm btn-outline-secondary">
                Mark read
              </button>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

</div>

<script>
$('.mark-read-btn').on('click', function() {
  const id = $(this).data('id');
  $.post('/notifications/read/' + id, function() {
    location.reload();
  });
});

$('#markAllRead').on('click', function() {
  $.post('/notifications/read-all', function() {
    location.reload();
  });
});
</script>

<%- include('../partials/footer') %>

<script>
async function markRead(id) {
  try {
    const res = await fetch(`/notifications/read/${id}`, {
      method: 'POST'
    });

    const data = await res.json();

    if (data.success) {
      location.reload(); // refresh page
    }
  } catch (err) {
    console.error(err);
  }
}
</script>
<script>
async function markAllRead() {
  try {
    const res = await fetch('/notifications/read-all', {
      method: 'POST'
    });

    const data = await res.json();

    if (data.success) {
      location.reload();
    }
  } catch (err) {
    console.error(err);
  }
}
</script>