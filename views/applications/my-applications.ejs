<%- include('../partials/header', { user }) %>

<div class="container mt-4">

  <h4 class="mb-4">My Applications</h4>

  <% if (success === 'applied') { %>
    <div class="alert alert-success">Application submitted successfully!</div>
  <% } %>
  <% if (error === 'already_applied') { %>
    <div class="alert alert-warning">You have already applied for this opportunity.</div>
  <% } %>

  <% if (applications.length === 0) { %>
    <div class="text-center text-muted mt-5">
      <h5>No applications yet</h5>
      <a href="/opportunities" class="btn btn-dark mt-3">Browse Opportunities</a>
    </div>
  <% } %>

  <% applications.forEach(app => { %>
    <div class="card mb-4 shadow-sm">
      <div class="card-body">

        <div class="d-flex justify-content-between align-items-start">
          <div>
            <h6 class="mb-1"><%= app.opportunity ? app.opportunity.title : 'Opportunity removed' %></h6>
            <p class="text-muted small mb-2">
              Applied on <%= new Date(app.createdAt).toLocaleDateString() %>
            </p>
          </div>

          <!-- Status badge -->
          <span class="badge status-badge status-<%= app.status.toLowerCase() %>">
            <%= app.status %>
          </span>
        </div>

        <!-- Status timeline -->
        <div class="status-timeline mt-3">
          <% const stages = ['Applied', 'Reviewing', 'Shortlisted', 'Accepted']; %>
          <% stages.forEach(stage => { %>
            <div class="timeline-step <%= app.status === stage ? 'active' : '' %> 
                         <%= ['Accepted', 'Shortlisted', 'Reviewing'].includes(app.status) && stages.indexOf(stage) < stages.indexOf(app.status) ? 'done' : '' %>
                         <%= app.status === 'Rejected' ? 'rejected' : '' %>">
              <div class="timeline-dot"></div>
              <div class="timeline-label"><%= stage %></div>
            </div>
          <% }) %>
          <% if (app.status === 'Rejected') { %>
            <div class="timeline-step rejected-final">
              <div class="timeline-dot"></div>
              <div class="timeline-label">Rejected</div>
            </div>
          <% } %>
        </div>

        <!-- Feedback if any -->
        <% if (app.feedback) { %>
          <div class="alert alert-info mt-3 mb-0 small">
            <strong>Feedback:</strong> <%= app.feedback %>
          </div>
        <% } %>

        <!-- SOP preview -->
        <div class="mt-3">
          <small class="text-muted">
            <strong>Your SOP:</strong> <%= app.sop.substring(0, 150) %>...
          </small>
        </div>

        <% if (app.documentUrl) { %>
          <a href="<%= app.documentUrl %>" target="_blank" 
             class="btn btn-outline-secondary btn-sm mt-2">
            📄 View Document
          </a>
        <% } %>

      </div>
    </div>
  <% }) %>

</div>

<%- include('../partials/footer') %>